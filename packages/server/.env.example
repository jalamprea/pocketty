# Puerto y host del backend.
# Por seguridad, NO uses 0.0.0.0. Deja 127.0.0.1 y expón con `tailscale serve`,
# o pon aquí la IP de tu interfaz Tailscale (100.x.y.z).
PORT=8723
HOST=127.0.0.1

# Secreto para firmar los JWT. Genera uno largo y aleatorio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Hash bcrypt de tu password. Genéralo con: npm run hash
# (NO guardes el password en texto plano).
PASSWORD_HASH=

# Tiempo de validez del token (ej: 7d, 12h).
TOKEN_TTL=7d

# Shell que usará tmux. En Mac normalmente /bin/zsh.
SHELL=/bin/zsh

# Carpeta de los estáticos del web build (servida en producción).
# Por defecto ../web/dist relativo al server.
WEB_DIR=
