# Backend port and host.
# For security, do NOT use 0.0.0.0. Keep 127.0.0.1 and expose with `tailscale serve`,
# or put here the IP of your Tailscale interface (100.x.y.z).
PORT=8723
HOST=127.0.0.1

# Secret for signing JWTs. Generate a long, random one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# bcrypt hash of your password. Generate it with: npm run hash
# (do NOT store the password in plain text).
PASSWORD_HASH=

# Token validity time (e.g. 7d, 12h).
TOKEN_TTL=7d

# Shell that tmux will use. On Mac usually /bin/zsh.
SHELL=/bin/zsh

# Folder for the web build's static files (served in production).
# Defaults to ../web/dist relative to the server.
WEB_DIR=

# Initial directory for each new session. ABSOLUTE path to an existing
# directory (e.g. /Users/julian/Dev). If left empty or invalid, sessions
# start in the server's cwd (where you run npm run dev).
START_DIR=

# Folder where the app's data is stored (shortcuts, in
# favorites.json). Defaults to ~/.pocketty.
DATA_DIR=
